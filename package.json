{
  "name": "knot",
  "version": "1.3.0",
  "description": "办公数字化工具 - 邮件驱动的工作流管理",
  "homepage": "https://github.com/jankiny/knot",
  "author": {
    "name": "Jankiny",
    "email": "yangzlnn@foxmail.com"
  },
  "main": "electron/main.js",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && set NODE_ENV=development&& electron .\"",
    "backend:build:win": "cd backend && conda run -n go go build -ldflags \"-s -w\" -o ..\\electron\\bin\\knot-backend.exe",
    "backend:build:linux": "cd backend && go build -ldflags \"-s -w\" -o ../electron/bin/knot-backend",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "pnpm run backend:build:win && vite build && electron-builder --win",
    "electron:build:linux": "pnpm run backend:build:linux && vite build && electron-builder --linux",
    "test": "vitest"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.0",
    "argparse": "2.0.1",
    "axios": "^1.6.0",
    "builder-util-runtime": "9.5.1",
    "dayjs": "^1.11.19",
    "debug": "4.4.3",
    "electron-updater": "6.8.3",
    "fs-extra": "10.1.0",
    "graceful-fs": "4.2.11",
    "js-yaml": "4.1.1",
    "jsonfile": "6.2.0",
    "lazy-val": "1.0.5",
    "lodash.escaperegexp": "4.1.2",
    "lodash.isequal": "4.5.0",
    "ms": "2.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sax": "1.4.4",
    "semver": "7.7.4",
    "tiny-typed-emitter": "2.1.0",
    "universalify": "2.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-devtools-installer": "^4.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jankiny.knot",
    "productName": "Knot",
    "copyright": "Copyright © 2026 Knot",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jankiny",
        "repo": "knot"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/bin/.gitkeep"
    ],
    "extraResources": [
      {
        "from": "electron/bin/",
        "to": "bin/",
        "filter": [
          "**/*",
          "!.gitkeep"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "unicode": true,
      "language": "2052",
      "artifactName": "${name}-win-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "electron/assets/icons",
      "artifactName": "${name}-linux-${version}-${arch}.${ext}"
    },
    "icon": "electron/assets/icons/512x512.png",
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
